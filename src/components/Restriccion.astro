<!-- ═══════════════════════════════════════════════════════════ --><!-- 👥 SECCIÓN: ACOMPAÑANTES (SIN NIÑOS)                        --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-20 pb-10 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE ACOMPAÑANTES -->
        <div class="flex justify-center">
            <div class="relative w-[280px]" id="card-acompanantes">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-acompanantes">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-acompanantes"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo acompañantes"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Contenido de la card -->
                    <div
                        class="relative px-4 pt-16 pb-12 z-10 flex flex-col items-center justify-center min-h-[200px]"
                    >
                        <!-- ICONO -->
                        <div class="mb-4">
                            <img
                                src="/imagenes/restriccion.png"
                                alt="Sin niños"
                                class="w-16 h-16 mx-auto object-contain icono-restriccion"
                            />
                        </div>

                        <!-- TEXTO PRINCIPAL -->
                        <div class="text-center" id="texto-acompanantes">
                            <p
                                class="font-crimson text-xl leading-relaxed text-[#122a4d]"
                            >
                                Aunque amamos a sus pequeños, este día especial
                                es solo para adultos. Agradecemos su comprensión.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP - SOLO AL BAJAR                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // Animación del botón decorativo
            gsap.fromTo(
                "#boton-decorativo-acompanantes",
                {
                    opacity: 0,
                    scale: 0,
                    rotation: -180,
                },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación de la card
            gsap.fromTo(
                "#card-principal-acompanantes",
                {
                    opacity: 0,
                    y: 50,
                    scale: 0.95,
                },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del texto
            gsap.fromTo(
                "#texto-acompanantes",
                {
                    opacity: 0,
                    y: 20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.3,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );
        });
    }
</script>

<style>
    .icono-restriccion {
        filter: brightness(0) saturate(100%) invert(14%) sepia(50%)
            saturate(1847%) hue-rotate(188deg) brightness(95%) contrast(95%);
    }
</style>
