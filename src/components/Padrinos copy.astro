<!-- ═══════════════════════════════════════════════════════════ --><!-- 👔 SECCIÓN: PADRINOS                                        --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-4 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE PADRINOS -->
        <div class="flex justify-center">
            <div class="relative w-full max-w-5xl" id="card-padrinos">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-padrinos">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-lg shadow-xl overflow-hidden bg-[#4a5f7f]"
                    id="card-principal-padrinos"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/azul.png"
                        alt="Fondo padrinos"
                        class="absolute inset-0 w-full h-full object-cover opacity-50"
                    />

                    <!-- Contenido de la card -->
                    <div
                        class="relative px-2 pt-16 pb-12 z-10"
                    >
                        <!-- TÍTULO PRINCIPAL -->
                        <div class="text-center mb-4">
                            <h2
                                class="font-great-vibes text-[2.25rem] leading-tight text-white"
                                id="titulo-padrinos"
                            >
                                Nuestros Padrinos
                            </h2>
                        </div>

                        <!-- GRID DE PADRINOS EN 2 COLUMNAS -->
                        <div
                            class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-12"
                            id="grid-padrinos"
                        >
                            <!-- COLUMNA 1 -->
                            <div class="space-y-6">
                                <!-- PADRINOS DE RELIGIÓN -->
                                <div class="text-center">
                                    <h3
                                        class="font-cormorant-sc text-xl uppercase tracking-wide text-white font-semibold mb-2"
                                    >
                                        Consejeros
                                    </h3>
                                    <p
                                        class="font-cormorant-sc text-lg leading-relaxed text-white"
                                    >
                                        Pastor Calani Ramos<br />
                                        Eva Janco Llanque
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // 🎯 ANIMACIÓN ELEGANTE DE ENTRADA
            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: "#card-padrinos",
                    start: "top 80%",
                    toggleActions: "play none none reset",
                },
            });

            // Botón decorativo
            tl.fromTo(
                "#boton-decorativo-padrinos",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                },
                0,
            );

            // Card entra desde abajo
            tl.fromTo(
                "#card-principal-padrinos",
                {
                    opacity: 0,
                    y: 50,
                    scale: 0.95,
                },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                },
                0,
            )
                // Título entra desde arriba
                .fromTo(
                    "#titulo-padrinos",
                    {
                        opacity: 0,
                        y: -30,
                    },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 1,
                        ease: "power2.out",
                    },
                    0,
                )
                // Grid de padrinos aparece con fade
                .fromTo(
                    "#grid-padrinos",
                    {
                        opacity: 0,
                    },
                    {
                        opacity: 1,
                        duration: 1,
                        ease: "power2.out",
                    },
                    0.3,
                );
        });
    }
</script>

<style>
    /* Aseguramos que Cormorant SC esté disponible */
    .font-cormorant-sc {
        font-family: "Cormorant SC", serif;
    }
</style>
