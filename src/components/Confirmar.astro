<!-- ═══════════════════════════════════════════════════════════ --><!-- 💬 SECCIÓN: CONFIRMA TU ASISTENCIA                         --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE CONFIRMAR ASISTENCIA -->
        <div class="flex justify-center">
            <div class="relative w-[300px]" id="card-confirmar">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div
                        class="w-16 h-16 sm:w-20 sm:h-20"
                        id="boton-decorativo-confirmar"
                    >
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-confirmar"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo confirmar"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Contenido de la card -->
                    <div
                        class="relative px-6 py-12 sm:px-8 sm:py-14 z-10 flex flex-col items-center justify-center"
                    >
                        <!-- TÍTULO PRINCIPAL -->
                        <div class="text-center mb-6" id="titulo-confirmar">
                            <h2
                                class="font-crimson text-2xl sm:text-3xl md:text-4xl text-[#122a4d] uppercase tracking-wide font-bold"
                            >
                                Confirma Tu<br />Asistencia
                            </h2>
                        </div>

                        <!-- TEXTO DESCRIPTIVO -->
                        <div class="text-center mb-8" id="texto-confirmar">
                            <p
                                class="font-crimson text-xl sm:text-lg text-[#122a4d] leading-relaxed"
                            >
                                Será de mucha alegría<br />
                                para nosotros contar<br />
                                con tu compañía en este<br />
                                día tan importante.
                            </p>
                        </div>
                        <!-- BOTONES FORMULARIO -->
                        <div
                            class="flex flex-col items-center gap-4 w-full"
                            id="boton-formulario-confirmar"
                        >
                            <!-- BOTÓN NOVIO -->
                            <a
                                href="https://wa.me/59163763979?text=Me%20complace%20confirmar%20mi%20asistencia%20a%20la%20boda%20de%20Rene%20y%20Lourdes.%20Nos%20vemos%20el%20s%C3%A1bado%2026%20de%20septiembre.%20%C2%A1Estar%C3%A9%20sin%20falta!"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex w-full max-w-xs
                            items-center justify-center gap-2 px-6 py-3 sm:px-8
                            sm:py-4 bg-[#122a4d] rounded-full shadow-lg
                            hover:shadow-xl hover:bg-[#1a3d6b] transition-all
                            duration-300"
                                aria-label="Confirmar asistencia con el novio"
                            >
                                <svg
                                    class="w-5 h-5 sm:w-6 sm:h-6 text-white shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                    ></path>
                                </svg>

                                <span
                                    class="font-crimson text-base sm:text-lg text-white font-semibold uppercase tracking-wider whitespace-nowrap"
                                >
                                    Confirmar (Novio)
                                </span>
                            </a>

                            <!-- BOTÓN NOVIA -->
                            <a
                                href="https://wa.me/59172485340?text=Me%20complace%20confirmar%20mi%20asistencia%20a%20la%20boda%20de%20Rene%20y%20Lourdes.%20Nos%20vemos%20el%20s%C3%A1bado%2026%20de%20septiembre.%20%C2%A1Estar%C3%A9%20sin%20falta!"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex w-full max-w-xs
                            items-center justify-center gap-2 px-6 py-3 sm:px-8
                            sm:py-4 bg-[#122a4d] rounded-full shadow-lg
                            hover:shadow-xl hover:bg-[#1a3d6b] transition-all
                            duration-300"
                                aria-label="Confirmar asistencia con la novia"
                            >
                                <svg
                                    class="w-5 h-5 sm:w-6 sm:h-6 text-white shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                    ></path>
                                </svg>

                                <span
                                    class="font-crimson text-base sm:text-lg text-white font-semibold uppercase tracking-wider whitespace-nowrap"
                                >
                                    Confirmar (Novia)
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 🎬 ANIMACIONES CON GSAP                                     -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        if (typeof window !== "undefined") {
            document.addEventListener("DOMContentLoaded", () => {
                console.log(
                    "💬 Iniciando animaciones de confirmar asistencia...",
                );

                // Animación del botón decorativo
                gsap.fromTo(
                    "#boton-decorativo-confirmar",
                    {
                        opacity: 0,
                        scale: 0,
                        rotation: -180,
                    },
                    {
                        opacity: 1,
                        scale: 1,
                        rotation: 0,
                        duration: 1,
                        ease: "back.out(1.7)",
                        scrollTrigger: {
                            trigger: "#card-confirmar",
                            start: "top 80%",
                            toggleActions: "play none none reset",
                        },
                    },
                );

                // Animación de la card
                gsap.fromTo(
                    "#card-principal-confirmar",
                    {
                        opacity: 0,
                        y: 50,
                        scale: 0.95,
                    },
                    {
                        opacity: 1,
                        y: 0,
                        scale: 1,
                        duration: 1,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: "#card-confirmar",
                            start: "top 80%",
                            toggleActions: "play none none reset",
                        },
                    },
                );

                // Animación del título
                gsap.fromTo(
                    "#titulo-confirmar",
                    {
                        opacity: 0,
                        y: -20,
                    },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        delay: 0.3,
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: "#card-confirmar",
                            start: "top 80%",
                            toggleActions: "play none none reset",
                        },
                    },
                );

                // Animación del texto
                gsap.fromTo(
                    "#texto-confirmar",
                    {
                        opacity: 0,
                        y: 20,
                    },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        delay: 0.5,
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: "#card-confirmar",
                            start: "top 80%",
                            toggleActions: "play none none reset",
                        },
                    },
                );

                // Animación del botón
                gsap.fromTo(
                    "#boton-formulario-confirmar",
                    {
                        opacity: 0,
                        scale: 0.8,
                        y: 20,
                    },
                    {
                        opacity: 1,
                        scale: 1,
                        y: 0,
                        duration: 0.8,
                        delay: 0.7,
                        ease: "back.out(1.5)",
                        scrollTrigger: {
                            trigger: "#card-confirmar",
                            start: "top 80%",
                            toggleActions: "play none none reset",
                        },
                    },
                );

                // Animación continua del botón decorativo
                gsap.to("#boton-decorativo-confirmar", {
                    y: -5,
                    duration: 2,
                    ease: "sine.inOut",
                    yoyo: true,
                    repeat: -1,
                    delay: 1,
                });

                // Animación continua del botón formulario
                gsap.to("#boton-formulario-confirmar a", {
                    y: -3,
                    duration: 2,
                    ease: "sine.inOut",
                    yoyo: true,
                    repeat: -1,
                    delay: 1,
                });

                console.log(
                    "💬✨ ¡Animaciones de confirmar asistencia activadas!",
                );
            });
        }
    </script>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 🎨 ESTILOS CSS                                              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <style>
        /* Efecto hover en la card */
        #card-principal-confirmar {
            transition: all 0.4s ease;
        }

        #card-principal-confirmar:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(18, 42, 77, 0.25);
        }

        /* Efecto en el botón */
        #boton-formulario-confirmar a:focus {
            outline: none;
        }

        #boton-formulario-confirmar a:active {
            outline: none;
            transform: scale(0.95);
        }
    </style>
</section>
